# ==========================================
# MarketsMaps Environment Variables Template
# ==========================================

# 1. DATABASE CONFIGURATION (PostgreSQL + PostGIS)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgrespassword
DATABASE_NAME=marketsmaps
# Direct database URL for Drizzle/Prisma
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/marketsmaps?schema=public

# 2. REDIS CONFIGURATION (WebSockets Adapter & Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 3. AUTHENTICATION (NestJS JWT)
JWT_SECRET=super-secret-jwt-key-replace-in-production
JWT_EXPIRATION_TIME=7d

# 4. FRONTEND CONFIGURATION (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# 5. BACKEND SERVER CONFIGURATION (NestJS)
PORT=3001
NODE_ENV=development
